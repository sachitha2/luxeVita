<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="EcoStay" />

    <style name="EcoStay.ScreenRoot">
        <item name="android:background">@drawable/bg_screen_gradient</item>
    </style>

    <style name="EcoStay.PageContainer">
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingTop">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingBottom">28dp</item>
    </style>

    <style name="EcoStay.Title">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="EcoStay.Subtitle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="EcoStay.PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">54dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="EcoStay.SecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">@color/surface_card</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="EcoStay.TextField" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface_card</item>
        <item name="boxStrokeColor">@color/card_stroke</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

</resources>
