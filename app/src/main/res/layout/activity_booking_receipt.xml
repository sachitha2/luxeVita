<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient">

    <androidx.constraintlayout.widget.ConstraintLayout
        style="@style/EcoStay.PageContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".ui.BookingReceiptActivity">

        <TextView
            android:id="@+id/tvReceiptTitle"
            style="@style/EcoStay.Title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/booking_receipt_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvReceiptBody"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_surface_card"
            android:lineSpacingExtra="3dp"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvReceiptTitle"
            tools:text="Receipt ID: RCP-11&#10;Booking ID: 11&#10;..." />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
