<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/EcoStay.PageContainer"
        xmlns:tools="http://schemas.android.com/tools"
        tools:context=".ui.RoomsActivity">

        <TextView
            android:id="@+id/tvRoomsTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/rooms_title"
            style="@style/EcoStay.Title"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/filterPanel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_filter_panel"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/tvRoomsTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Spinner
                android:id="@+id/spRoomTypeFilter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvRoomsFilterHint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Refine by room type, price, and dates."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                app:layout_constraintTop_toBottomOf="@id/spRoomTypeFilter"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilMinPrice"
                style="@style/EcoStay.TextField"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/tvRoomsFilterHint"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tilMaxPrice">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMinPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Min price"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilMaxPrice"
                style="@style/EcoStay.TextField"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/tvRoomsFilterHint"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tilMinPrice">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMaxPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Max price"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnPickStart"
                style="@style/EcoStay.SecondaryButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Check-in"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/tilMaxPrice"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnPickEnd" />

            <Button
                android:id="@+id/btnPickEnd"
                style="@style/EcoStay.SecondaryButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Check-out"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/tilMaxPrice"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnPickStart" />

            <TextView
                android:id="@+id/tvDateRange"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="No date range selected"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/btnPickEnd"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <Spinner
                android:id="@+id/spSort"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/tvDateRange"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <Button
                android:id="@+id/btnApplyFilters"
                style="@style/EcoStay.PrimaryButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Apply filters"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/spSort"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRooms"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/filterPanel"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvRoomsEmptyState"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/rooms_empty"
            android:textAlignment="center"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/rvRooms"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>

